{
  "compilerOptions": {
    "outDir": "./dist",

    "module": "commonjs",
    "target": "es2019",

    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    "strict": true,
    "jsx": "react-jsx",

    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true,

    "esModuleInterop": true
  },
  "include": ["backend", "netlify/functions"]
}
